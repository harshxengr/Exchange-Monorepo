{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["DATABASE_URL", "NEXTAUTH_SECRET", "NEXTAUTH_URL", "REDIS_URL", "NEXT_PUBLIC_API_URL", "NEXT_PUBLIC_WS_URL"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "db:generate": { 
      "cache": false
    }, 
    "db:migrate": { 
      "cache": false
    }, 
    "db:deploy": { 
      "cache": false
    } 
  }
}