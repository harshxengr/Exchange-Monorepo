{
  "name": "exchange-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @exchange/db db:generate",
    "db:migrate": "pnpm --filter @exchange/db db:migrate",
    "db:deploy": "pnpm --filter @exchange/db db:deploy",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "packageManager": "pnpm@10.25.0",
  "devDependencies": {
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  }
}