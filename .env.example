# Global Settings Config
NODE_ENV=development

# Port
PORT=3000
WS_PORT=8080
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Auth (web app runs on port 3002 in dev)
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=change-me-to-a-random-secret-in-production

# Service Connection String URIs
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/exchange_db?schema=public